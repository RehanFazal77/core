apiVersion: kpt.dev/v1
kind: Kptfile
metadata: # kpt-merge: /platform-addons
  name: platform-addons
  annotations:
    config.kubernetes.io/local-config: "true"
    internal.kpt.dev/upstream-identifier: 'kpt.dev|Kptfile|default|platform-addons'
upstream:
  type: git
  git:
    repo: https://github.com/RehanFazal77/nephio-workload-blueprints.git
    directory: platform-addons
    ref: main
upstreamLock:
  type: git
  git:
    repo: https://github.com/RehanFazal77/nephio-workload-blueprints.git
    directory: platform-addons
    ref: main
    commit: 17e48a46aa5f7ee0f2467941fa7a8525e5b88ed3
info:
  site: https://nephio.org
  description: Platform add-ons for Nephio workload clusters (storage, monitoring, resource management)
  keywords:
  - nephio
  - addons
  - storage
  - monitoring
pipeline:
  mutators:
  - name: PackageVariant.addons-core..0
    image: ghcr.io/kptdev/krm-functions-catalog/apply-setters:v0.2
    configMap:
      cluster-name: core
  - image: ghcr.io/kptdev/krm-functions-catalog/apply-setters:v0.2
    configMap:
      cluster-name: my-ran
      enable-metrics-server: "true"
      enable-nginx-ingress: "false"
      enable-prometheus: "false"
      local-path-provisioner: "true"
      storage-class-name: local-path
